generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model HomeContent {
  id                     String   @id @default("home")
  heroTitle              String   @default("Welcome to Yahya Hub")
  heroSubtitle           String   @default("A vibrant space for ideas, creativity, and collaboration. We offer coworking spaces, run skill-building programs, and host events that inspire innovation across every field.")
  heroCtaPrimaryText     String   @default("Explore Workspaces")
  heroCtaPrimaryAnchor   String   @default("workspaces")
  heroCtaSecondaryText   String   @default("Our Programs")
  heroCtaSecondaryAnchor String   @default("programs")
  heroVideoUrl           String   @default("https://firebasestorage.googleapis.com/v0/b/yahyahub-e7643.firebasestorage.app/o/bookings-n-products%2Fhero%2Fvideo%2Fyahya_hub_commercial.mp4?alt=media&token=24f59eeb-8203-4a75-8763-0c1d4454b9b7")
  updatedAt              DateTime @updatedAt

  @@map("home_content")
}

model FooterContent {
  id        String   @id @default("footer")
  email     String   @default("yahyahub6@gmail.com")
  phone     String   @default("07043925169")
  facebook  String   @default("https://www.facebook.com/share/1913yPdrYe/")
  twitter   String   @default("https://x.com/YahyaHub")
  linkedin  String   @default("https://www.linkedin.com/company/yahyahub/posts")
  updatedAt DateTime @updatedAt

  @@map("footer_content")
}

model StatusCard {
  id           String @id @default(cuid())
  title        String
  icon         String
  badgeLabel   String
  badgeVariant String @default("green")
  primary      String
  secondary    String
  order        Int    @default(0)

  @@map("status_cards")
}

model Workspace {
  id             String  @id @default(cuid())
  name           String
  description    String
  rating         Float   @default(4.5)
  reviewCount    Int     @default(0)
  hourlyRate     Int     @default(0)
  dailyRate      Int     @default(0)
  imageUrl       String
  bookingEnabled Boolean @default(true)
  amenities      String  @default("[]")
  order          Int     @default(0)

  @@map("workspaces")
}

model Program {
  id          String  @id @default(cuid())
  name        String
  description String
  category    String
  duration    String
  price       Int     @default(0)
  status      String  @default("upcoming")
  cohort      String?
  type        String?
  enrollable  Boolean @default(true)
  imageUrl    String?
  order       Int     @default(0)

  @@map("programs")
}

model EventItem {
  id           String  @id @default(cuid())
  title        String
  description  String
  longWriteUp  String?
  category     String
  mode         String  @default("Physical")
  isMostRecent Boolean @default(false)
  status       String  @default("upcoming")
  date         String
  time         String
  location     String
  audience     String
  fee          Int     @default(0)
  instagramUrl String  @default("https://www.instagram.com/yahyahub/")
  imageUrl     String?
  videoUrl     String?
  bookable     Boolean @default(true)
  list         String  @default("home")
  order        Int     @default(0)

  @@map("events")
}

// Per-workspace availability config set by admin
model WorkspaceAvailability {
  id            String @id @default(cuid())
  workspaceId   String @unique
  availableDays String @default("[1,2,3,4,5]")
  openTime      String @default("09:00")
  closeTime     String @default("20:00")
  slotDuration  Int    @default(60)
  blackoutDates String @default("[]")

  @@map("workspace_availability")
}

// Confirmed workspace bookings
model WorkspaceBooking {
  id          String   @id @default(cuid())
  workspaceId String
  ticketId    String   @unique
  date        String
  startTime   String
  endTime     String
  type        String   @default("hourly")
  name        String
  email       String
  phone       String
  notes       String
  amount      Int      @default(0)
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  @@map("workspace_bookings")
}

// Course / program enrollments
model CourseEnrollment {
  id          String   @id @default(cuid())
  programId   String
  ticketId    String   @unique
  name        String
  email       String
  phone       String
  gender      String?
  education   String?
  amount      Int      @default(0)
  paystackRef String?
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  @@map("course_enrollments")
}

// Event registrations
model EventRegistration {
  id          String   @id @default(cuid())
  eventId     String
  ticketId    String   @unique
  name        String
  email       String
  phone       String
  gender      String?
  amount      Int      @default(0)
  paystackRef String?
  status      String   @default("confirmed")
  createdAt   DateTime @default(now())

  @@map("event_registrations")
}

// About page config (single JSON blob)
model AboutConfig {
  id   String @id @default("about")
  data String

  @@map("about_config")
}
