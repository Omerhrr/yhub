# ── Paystack ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_SECRET_KEY=sk_test_xxx

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Yahya Hub <your-email@gmail.com>"

# ── Site URL (used in ticket emails) ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yahyahub.ng

# ── Admin credentials ─────────────────────────────────────────────────────────
# Change these before deploying to production!
ADMIN_EMAIL=admin@yahyahub.ng
ADMIN_PASSWORD=change-me-before-deploy
ADMIN_SECRET=change-me-before-deploy
